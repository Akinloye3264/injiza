# Backend environment variables
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Africa's Talking credentials
AT_API_KEY=your_africastalking_api_key_here
AT_USERNAME=your_africastalking_username_here
AT_SHORTCODE=*384*your_code#

# Server
PORT=3001

# Set this to your ngrok/deployed URL so Swagger shows the right server
# e.g. https://oppressed-preflight-cupping.ngrok-free.dev
PUBLIC_URL=
